#!/bin/bash

# gstack subtitle-remove — CLI wrapper for SubtitleRemover.app
# Integrates with gstack skill system + OpenCode Go

set -e

APP_PATH="/Applications/SubtitleRemover.app/Contents/MacOS/SubtitleRemover"
CONFIG_DIR="$HOME/.subtitle-remover"
OUTPUT_FORMAT="json"
MODEL="lama"
DISABLE_GPU=false
BATCH_MODE=false
MAX_PARALLEL=2
QUALITY="medium"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Usage
usage() {
    cat << 'EOF'
Usage: gstack-subtitle-remove <video-path> [OPTIONS]

OPTIONS:
  -o, --output PATH          Output video path (default: {input}_cleaned.{ext})
  -m, --model MODEL          Inpainting model: sttn|lama|propainter (default: lama)
  -l, --language LANG        Subtitle language: auto|en|zh|es|fr|ja|ko (default: auto)
  --batch                    Process all videos in directory
  --max-parallel N           Max parallel jobs (default: 2)
  --no-gpu                   Force CPU-only mode
  -q, --quality LEVEL        Detection quality: low|medium|high (default: medium)
  -f, --format FORMAT        Output format: json|csv (default: json)
  -h, --help                 Show this help

EXAMPLES:
  gstack-subtitle-remove ~/video.mp4 -o ~/video_clean.mp4
  gstack-subtitle-remove ~/video.mp4 --model lama --no-gpu
  gstack-subtitle-remove ~/Videos/ --batch --max-parallel 2

EOF
    exit 0
}

# Parse arguments
VIDEO_PATH=""
OUTPUT_PATH=""
LANGUAGE="auto"

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage
            ;;
        -o|--output)
            OUTPUT_PATH="$2"
            shift 2
            ;;
        -m|--model)
            MODEL="$2"
            shift 2
            ;;
        -l|--language)
            LANGUAGE="$2"
            shift 2
            ;;
        --batch)
            BATCH_MODE=true
            shift
            ;;
        --max-parallel)
            MAX_PARALLEL="$2"
            shift 2
            ;;
        --no-gpu)
            DISABLE_GPU=true
            shift
            ;;
        -q|--quality)
            QUALITY="$2"
            shift 2
            ;;
        -f|--format)
            OUTPUT_FORMAT="$2"
            shift 2
            ;;
        *)
            if [[ -z "$VIDEO_PATH" ]]; then
                VIDEO_PATH="$1"
            fi
            shift
            ;;
    esac
done

# Validation
if [[ -z "$VIDEO_PATH" ]]; then
    echo -e "${RED}❌ Video path required${NC}"
    usage
fi

if [[ ! -e "$VIDEO_PATH" ]]; then
    echo -e "${RED}❌ Video not found: $VIDEO_PATH${NC}"
    exit 1
fi

if [[ ! -f "$APP_PATH" ]]; then
    echo -e "${RED}❌ SubtitleRemover.app not found at $APP_PATH${NC}"
    echo "Install from: https://github.com/pestly/video-subtitle-remover/releases"
    exit 1
fi

# Setup config
mkdir -p "$CONFIG_DIR"
CONFIG_FILE="$CONFIG_DIR/config.json"

# Create default config if not exists
if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" << EOJSON
{
  "model": "$MODEL",
  "disable_gpu": $([[ "$DISABLE_GPU" == true ]] && echo "true" || echo "false"),
  "language": "$LANGUAGE",
  "quality": "$QUALITY",
  "output_format": "$OUTPUT_FORMAT"
}
EOJSON
fi

# Determine output path
if [[ -z "$OUTPUT_PATH" ]]; then
    DIR=$(dirname "$VIDEO_PATH")
    FILENAME=$(basename "$VIDEO_PATH")
    BASENAME="${FILENAME%.*}"
    EXT="${FILENAME##*.}"
    OUTPUT_PATH="$DIR/${BASENAME}_cleaned.$EXT"
fi

echo -e "${GREEN}🎬 Subtitle Remover${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Input:  $VIDEO_PATH"
echo "Output: $OUTPUT_PATH"
echo "Model:  $MODEL"
echo "GPU:    $([[ "$DISABLE_GPU" == true ]] && echo "Disabled (CPU-only)" || echo "Auto")"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Build args
ARGS=(
    "--video" "$VIDEO_PATH"
    "--output" "$OUTPUT_PATH"
    "--model" "$MODEL"
    "--language" "$LANGUAGE"
    "--quality" "$QUALITY"
)

if [[ "$DISABLE_GPU" == true ]]; then
    ARGS+=("--no-gpu")
fi

# Run
echo -e "${YELLOW}⏳ Processing... (this may take 5-20 minutes)${NC}"
START_TIME=$(date +%s)

if ! "$APP_PATH" "${ARGS[@]}"; then
    echo -e "${RED}❌ Processing failed${NC}"
    exit 1
fi

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))
ELAPSED_MIN=$((ELAPSED / 60))

# Output result
if [[ ! -f "$OUTPUT_PATH" ]]; then
    echo -e "${RED}❌ Output file not created${NC}"
    exit 1
fi

OUTPUT_SIZE=$(du -h "$OUTPUT_PATH" | cut -f1)

if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    cat > "$CONFIG_DIR/last_result.json" << EOJSON
{
  "status": "success",
  "input": "$VIDEO_PATH",
  "output": "$OUTPUT_PATH",
  "model": "$MODEL",
  "duration_seconds": $ELAPSED,
  "output_size": "$OUTPUT_SIZE",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOJSON
    cat "$CONFIG_DIR/last_result.json"
else
    echo "success,$VIDEO_PATH,$OUTPUT_PATH,$MODEL,$ELAPSED,$OUTPUT_SIZE"
fi

echo -e "${GREEN}✅ Complete in ${ELAPSED_MIN}m${NC}"
echo "Result: $OUTPUT_PATH ($OUTPUT_SIZE)"
